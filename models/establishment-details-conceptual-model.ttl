    a owl:ObjectProperty ;
    rdfs:label "classified by further education type"@en ;
    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:FurtherEducationType ;
    rdfs:comment "Cardinality: 0..1. Present for further education (type 18), higher education institutions (type 29) and pupil referral units (type 14)."@en .

epro:classifiedBySection41Approval
    a owl:ObjectProperty ;
    rdfs:label "classified by Section 41 approval status"@en ;
    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:Section41Approval ;
    rdfs:comment "Cardinality: 0..1. Present for non-maintained special schools, independent special schools, and many academy and free school types."@en .


#################################################################
# Object properties — inspection detail
#################################################################

epro:recordsInspectorateName
    a owl:ObjectProperty ;
    rdfs:label "records inspectorate name"@en ;
    rdfs:domain epr:InspectionReportReference ;
    rdfs:range epr:InspectorateName ;
    rdfs:comment "Cardinality: 0..1. Present where the inspectorate is not Ofsted."@en .

epro:recordsDateOfLastInspectionVisit
    a owl:ObjectProperty ;
    rdfs:label "records date of last inspection visit"@en ;
    rdfs:domain epr:InspectionReportReference ;
    rdfs:range epr:DateOfLastInspectionVisit ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:recordsDateOfNextInspectionVisit
    a owl:ObjectProperty ;
    rdfs:label "records date of next inspection visit"@en ;
    rdfs:domain epr:InspectionReportReference ;
    rdfs:range epr:DateOfNextInspectionVisit ;
    rdfs:comment "Cardinality: 0..1. Observed for British schools overseas (type 37)."@en .


#################################################################
# Object properties — special pupils SEN measures
#################################################################

epro:hasSpecialPupilMeasure
    a owl:ObjectProperty ;
    rdfs:label "has special pupil measure"@en ;
    rdfs:domain epr:SenAndResourcedProvision ;
    rdfs:range epr:SpecialPupilMeasure ;
    rdfs:comment "Cardinality: 0..1. Covers the count of pupils with a SEN statement or EHC plan and the count without."@en .


#################################################################
# Classes — Ofsted inspection record (v0.4)
#################################################################

epr:OfstedInspectionRecord
    a owl:Class ;
    rdfs:label "Ofsted inspection record"@en ;
    rdfs:comment "A record of the establishment's Ofsted inspection rating and associated report link. Distinct from inspection records held by non-Ofsted inspectorates (e.g. ISI, Ofsted independent school inspectorates) which are modelled under InspectionReportReference."@en .


#################################################################
# Classes — PRU operational record (v0.4)
#################################################################

epr:PupilReferralUnitOperationalRecord
    a owl:Class ;
    rdfs:label "Pupil referral unit operational record"@en ;
    rdfs:comment "The group of operational fields specific to pupil referral units, covering teenage mothers provision, childcare, SEN facilities, EBD pupils and number of places."@en .


#################################################################
# Classes — accreditation record (v0.4, online providers)
#################################################################

epr:AccreditationRecord
    a owl:Class ;
    rdfs:label "Accreditation record"@en ;
    rdfs:comment "The group of accreditation fields for online providers, including accreditation dates, quality assurance body, companies house number and accreditation status."@en .


#################################################################
# Classes — children's centre specific (v0.4)
#################################################################

epr:ProviderType
    a owl:Class ;
    rdfs:label "Provider type"@en ;
    rdfs:comment "The classification of provider type for a children's centre establishment."@en .

epr:CentreManager
    a owl:Class ;
    rdfs:label "Centre manager"@en ;
    rdfs:comment "The named manager of a children's centre. Distinct from HeadteacherOrPrincipal — children's centres show the Centre manager role rather than Headteacher/Principal in the GIAS Details view."@en .


#################################################################
# Object properties — Ofsted inspection record (v0.4)
#################################################################

epro:hasOfstedInspectionRecord
    a owl:ObjectProperty ;
    rdfs:label "has Ofsted inspection record"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:OfstedInspectionRecord ;
    rdfs:comment "Cardinality: 0..1. Present for establishment types that are inspected by Ofsted. Absent for Welsh establishments, BSOs (inspected by other inspectorates), sixth form centres, children's centres and academy secure 16-19."@en .


#################################################################
# Object properties — PRU operational record (v0.4)
#################################################################

epro:hasPupilReferralUnitOperationalRecord
    a owl:ObjectProperty ;
    rdfs:label "has pupil referral unit operational record"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:PupilReferralUnitOperationalRecord ;
    rdfs:comment "Cardinality: 0..1. Present only for pupil referral units (type 14)."@en .

epro:hasTeenageMothersProvision
    a owl:DatatypeProperty ;
    rdfs:label "has teenage mothers provision"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the PRU provides for teenage mothers."@en .

epro:hasTeenageMothersPlaces
    a owl:DatatypeProperty ;
    rdfs:label "has teenage mothers places"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Cardinality: 0..1. Number of places for teenage mothers."@en .

epro:hasChildcareProvision
    a owl:DatatypeProperty ;
    rdfs:label "has childcare provision"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the PRU provides childcare facilities."@en .

epro:hasSenFacilities
    a owl:DatatypeProperty ;
    rdfs:label "has SEN facilities"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the PRU has SEN facilities."@en .

epro:hasPupilsWithEBD
    a owl:DatatypeProperty ;
    rdfs:label "has pupils with EBD"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the PRU provides for pupils with emotional and behavioural difficulties."@en .

epro:hasNumberOfPlaces
    a owl:DatatypeProperty ;
    rdfs:label "has number of places"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Cardinality: 0..1. Total number of places in the PRU."@en .

epro:hasFullTimeProvision
    a owl:DatatypeProperty ;
    rdfs:label "has full time provision"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the PRU offers full-time provision."@en .

epro:hasPupilsEducatedByOtherProviders
    a owl:DatatypeProperty ;
    rdfs:label "has pupils educated by other providers"@en ;
    rdfs:domain epr:PupilReferralUnitOperationalRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the PRU has pupils educated by other providers."@en .


#################################################################
# Object properties — accreditation record (v0.4)
#################################################################

epro:hasAccreditationRecord
    a owl:ObjectProperty ;
    rdfs:label "has accreditation record"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:AccreditationRecord ;
    rdfs:comment "Cardinality: 0..1. Present only for online providers (type 49)."@en .

epro:hasAccreditationDate
    a owl:DatatypeProperty ;
    rdfs:label "has accreditation date"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:date ;
    rdfs:comment "Cardinality: 0..1. The date the online provider was accredited."@en .

epro:hasAccreditationExpiryDate
    a owl:DatatypeProperty ;
    rdfs:label "has accreditation expiry date"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:date ;
    rdfs:comment "Cardinality: 0..1. The date the accreditation expires."@en .

epro:hasAccreditationDateEnded
    a owl:DatatypeProperty ;
    rdfs:label "has accreditation date ended"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:date ;
    rdfs:comment "Cardinality: 0..1. The date the accreditation ended if it was revoked or lapsed."@en .

epro:hasQualityAssuranceBodyName
    a owl:DatatypeProperty ;
    rdfs:label "has quality assurance body name"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:string ;
    rdfs:comment "Cardinality: 0..1. The name of the quality assurance body for the online provider."@en .

epro:hasQualityAssuranceBodyReport
    a owl:DatatypeProperty ;
    rdfs:label "has quality assurance body report"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "Cardinality: 0..1. URL of the quality assurance body report for the online provider."@en .

epro:hasCompaniesHouseNumber
    a owl:DatatypeProperty ;
    rdfs:label "has companies house number"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:string ;
    rdfs:comment "Cardinality: 0..1. The Companies House registration number for the online provider."@en .

epro:isEstablishmentAccredited
    a owl:DatatypeProperty ;
    rdfs:label "is establishment accredited"@en ;
    rdfs:domain epr:AccreditationRecord ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Cardinality: 0..1. Whether the online provider is currently accredited."@en .


#################################################################
# Object properties — children's centre specific (v0.4)
#################################################################

epro:classifiedByProviderType
    a owl:ObjectProperty ;
    rdfs:label "classified by provider type"@en ;
    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:ProviderType ;
    rdfs:comment "Cardinality: 0..1. Present for children's centres (types 47 and 48)."@en .

epro:hasCentreManager
    a owl:ObjectProperty ;
    rdfs:label "has centre manager"@en ;
    rdfs:domain epr:EstablishmentLocationAndContact ;
    rdfs:range epr:CentreManager ;
    rdfs:comment "Cardinality: 0..1. Present for children's centres (types 47 and 48). Distinct from hasHeadteacherOrPrincipal — children's centres show a centre manager role."@en .


#################################################################
# Classes — establishment type hierarchy
#
# Intermediate OWL classes grouping establishment types by their
# SHACL shape family. Leaf type classes (CommunitySchool etc.)
# are declared below in their own section.
#################################################################

epr:LaMaintainedSchool
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "LA maintained school"@en ;
    rdfs:comment "Any school maintained by a local authority: community schools, voluntary schools, foundation schools, community and foundation special schools, pupil referral units, and local authority nursery schools."@en .

epr:LaMainstreamSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool ;
    rdfs:label "LA mainstream school"@en ;
    rdfs:comment "LA maintained mainstream schools: community school, voluntary aided school, voluntary controlled school, foundation school."@en .

epr:LaMaintainedSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool ;
    rdfs:label "LA maintained special school"@en ;
    rdfs:comment "LA maintained special schools: community special school, foundation special school."@en .

epr:NonMaintainedAndIndependentSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Non-maintained and independent special school"@en ;
    rdfs:comment "Non-maintained special schools and other independent special schools approved under section 342 of the Education Act 1996."@en .

epr:IndependentSchool
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Independent school"@en ;
    rdfs:comment "Independent schools: city technology colleges and other independent schools."@en .

epr:College
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "College"@en ;
    rdfs:comment "Further education establishments: further education colleges and sixth form centres."@en .

epr:Academy
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Academy"@en ;
    rdfs:comment "All academy types: mainstream, special, alternative provision, 16-19, and secure 16-19."@en .

epr:MainstreamAcademy
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Mainstream academy"@en ;
    rdfs:comment "Mainstream academies: academy sponsor led and academy converter."@en .

epr:AcademySpecial
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy special school"@en ;
    rdfs:comment "Academy special schools: academy special sponsor led and academy special converter."@en .

epr:AcademyAlternativeProvision
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy alternative provision"@en ;
    rdfs:comment "Academy alternative provision establishments: academy alternative provision converter and academy alternative provision sponsor led."@en .

epr:Academy1619
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy 16 to 19"@en ;
    rdfs:comment "Academy 16-19 establishments: academy 16-19 converter and academy 16 to 19 sponsor led."@en .

epr:FreeSchoolEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Free school establishment"@en ;
    rdfs:comment "All free school types: mainstream free schools, free school special, free school alternative provision, and free school 16 to 19."@en .

epr:MainstreamFreeSchool
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment ;
    rdfs:label "Mainstream free school"@en ;
    rdfs:comment "Mainstream free schools: free school, university technical college, studio school."@en .

epr:ChildrensCentreEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Children's centre establishment"@en ;
    rdfs:comment "Children's centres and children's centre linked sites."@en .


#################################################################
# Classes — establishment type leaf classes (v0.7)
#
# OWL class declarations for the 41 GIAS leaf establishment types,
# moved here from the taxonomy TTL. The taxonomy TTL retains the
# skos:Concept declarations and SKOS hierarchy (skos:broader).
# OWL 2 punning is preserved across both files.
#################################################################

# LA maintained mainstream schools
epr:CommunitySchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool .

epr:VoluntaryAidedSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool .

epr:VoluntaryControlledSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool .

epr:FoundationSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool .

# LA maintained special schools
epr:CommunitySpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSpecialSchool .

epr:FoundationSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSpecialSchool .

# LA maintained — other
epr:PupilReferralUnit
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool .

epr:LocalAuthorityNurserySchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool .

# Non-maintained and independent special schools
epr:NonMaintainedSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:NonMaintainedAndIndependentSpecialSchool .

epr:OtherIndependentSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:NonMaintainedAndIndependentSpecialSchool .

# Independent schools
epr:CityTechnologyCollege
    a owl:Class ;
    rdfs:subClassOf epr:IndependentSchool .

epr:OtherIndependentSchool
    a owl:Class ;
    rdfs:subClassOf epr:IndependentSchool .

# Colleges
epr:FurtherEducation
    a owl:Class ;
    rdfs:subClassOf epr:College .

epr:SixthFormCentre
    a owl:Class ;
    rdfs:subClassOf epr:College .

# Universities and higher education
epr:HigherEducationInstitution
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

# Welsh establishments
epr:WelshEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

# Other types
epr:SecureUnits
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

epr:OffshoreSchools
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

epr:ServiceChildrensEducation
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

epr:MiscellaneousEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

epr:SpecialPost16Institution
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

epr:BritishSchoolsOverseas
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

epr:InstitutionFundedByOtherGovernmentDepartment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment .

# Academies
epr:AcademySponsorLed
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamAcademy .

epr:AcademySpecialSponsorLed
    a owl:Class ;
    rdfs:subClassOf epr:AcademySpecial .

epr:AcademyConverter
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamAcademy .

epr:AcademyAlternativeProvisionConverter
    a owl:Class ;
    rdfs:subClassOf epr:AcademyAlternativeProvision .

