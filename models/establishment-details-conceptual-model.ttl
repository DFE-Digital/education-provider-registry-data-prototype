epr:AcademySecure16To19
    a owl:Class ;
    rdfs:subClassOf epr:Academy .

# Free schools
epr:FreeSchool
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamFreeSchool .

epr:FreeSchoolSpecial
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment .

epr:FreeSchoolAlternativeProvision
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment .

epr:FreeSchool16To19
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment .

