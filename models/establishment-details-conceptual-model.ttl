epr:NotApplicableSixthFormProvision
    a owl:NamedIndividual, epr:SixthFormProvision ;
    rdfs:label "Not applicable (sixth-form provision)"@en .

# Special-class provision (3 values)
epr:HasSpecialClasses
    a owl:NamedIndividual, epr:SpecialClassProvision ;
    rdfs:label "Has special classes"@en .

epr:NoSpecialClasses
    a owl:NamedIndividual, epr:SpecialClassProvision ;
    rdfs:label "No special classes"@en .

epr:NotApplicableSpecialClassProvision
    a owl:NamedIndividual, epr:SpecialClassProvision ;
    rdfs:label "Not applicable (special-class provision)"@en .
