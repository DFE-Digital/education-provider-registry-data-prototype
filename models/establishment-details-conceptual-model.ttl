    rdfs:domain epr:EstablishmentLocationAndContact ;
    rdfs:range epr:Website ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:hasTelephoneNumber
    a owl:ObjectProperty ;
    rdfs:label "has telephone number"@en ;
    rdfs:domain epr:EstablishmentLocationAndContact ;
    rdfs:range epr:TelephoneNumber ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:hasHeadteacherOrPrincipal
    a owl:ObjectProperty ;
    rdfs:label "has headteacher or principal"@en ;
    rdfs:domain epr:EstablishmentLocationAndContact ;
    rdfs:range epr:HeadteacherOrPrincipal ;
    rdfs:comment "Cardinality: 0..1."@en .


