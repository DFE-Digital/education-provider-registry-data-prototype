#################################################################
# Classes — Ofsted inspection record (v0.4)
#################################################################

epr:OfstedInspectionRecord
    a owl:Class ;
    rdfs:label "Ofsted inspection record"@en ;
    rdfs:comment "A record of the establishment's Ofsted inspection rating and associated report link. Distinct from inspection records held by non-Ofsted inspectorates (e.g. ISI, Ofsted independent school inspectorates) which are modelled under InspectionReportReference."@en .


#################################################################
# Classes — PRU operational record (v0.4)
#################################################################

epr:PupilReferralUnitOperationalRecord
    a owl:Class ;
    rdfs:label "Pupil referral unit operational record"@en ;
    rdfs:comment "The group of operational fields specific to pupil referral units, covering teenage mothers provision, childcare, SEN facilities, EBD pupils and number of places."@en .

epr:TeenageMothersProvision
    a owl:Class ;
    rdfs:label "Teenage mothers provision"@en ;
    rdfs:comment "Whether the pupil referral unit provides for teenage mothers."@en .

epr:TeenageMothersPlaces
    a owl:Class ;
    rdfs:label "Teenage mothers places"@en ;
    rdfs:comment "The number of places available for teenage mothers in the pupil referral unit."@en .

epr:ChildcareProvision
    a owl:Class ;
    rdfs:label "Childcare provision"@en ;
    rdfs:comment "Whether the pupil referral unit provides childcare facilities."@en .

epr:SenFacilities
    a owl:Class ;
    rdfs:label "SEN facilities"@en ;
    rdfs:comment "Whether the pupil referral unit has facilities for pupils with special educational needs."@en .

epr:PupilsWithEBD
    a owl:Class ;
    rdfs:label "Pupils with EBD"@en ;
    rdfs:comment "Whether the pupil referral unit provides for pupils with emotional and behavioural difficulties."@en .

epr:NumberOfPlaces
    a owl:Class ;
    rdfs:label "Number of places"@en ;
    rdfs:comment "The total number of places in the pupil referral unit."@en .

epr:FullTimeProvision
    a owl:Class ;
    rdfs:label "Full time provision"@en ;
    rdfs:comment "Whether the pupil referral unit offers full-time provision."@en .

epr:PupilsEducatedByOtherProviders
    a owl:Class ;
    rdfs:label "Pupils educated by other providers"@en ;
    rdfs:comment "Whether the pupil referral unit has pupils educated by other providers."@en .


#################################################################
# Classes — accreditation record (v0.4, online providers)
#################################################################

epr:AccreditationRecord
    a owl:Class ;
    rdfs:label "Accreditation record"@en ;
    rdfs:comment "The group of accreditation fields for online providers, including accreditation dates, quality assurance body, companies house number and accreditation status."@en .

epr:AccreditationDate
    a owl:Class ;
    rdfs:label "Accreditation date"@en ;
    rdfs:comment "The date on which the online provider was accredited."@en .

epr:AccreditationExpiryDate
    a owl:Class ;
    rdfs:label "Accreditation expiry date"@en ;
    rdfs:comment "The date on which the online provider's accreditation expires."@en .

epr:AccreditationDateEnded
    a owl:Class ;
    rdfs:label "Accreditation date ended"@en ;
    rdfs:comment "The date on which the online provider's accreditation was revoked or lapsed."@en .

epr:QualityAssuranceBodyName
    a owl:Class ;
    rdfs:label "Quality assurance body name"@en ;
    rdfs:comment "The name of the quality assurance body responsible for the online provider's accreditation."@en .

epr:QualityAssuranceBodyReport
    a owl:Class ;
    rdfs:label "Quality assurance body report"@en ;
    rdfs:comment "A reference to the quality assurance body's published report for the online provider."@en .

epr:CompaniesHouseNumber
    a owl:Class ;
    rdfs:label "Companies House number"@en ;
    rdfs:comment "A Companies House registration number. Currently scoped to online providers via AccreditationRecord (epro:hasCompaniesHouseNumber) and to establishment groups (epro:hasGroupCompaniesHouseNumber). The same class is reused across both contexts."@en .

epr:AccreditationStatus
    a owl:Class ;
    rdfs:label "Accreditation status"@en ;
    rdfs:comment "Whether the online provider is currently accredited."@en .


#################################################################
# Classes — children's centre specific (v0.4)
#################################################################

epr:ProviderType
    a owl:Class ;
    rdfs:label "Provider type"@en ;
    rdfs:comment "The classification of provider type for a children's centre establishment."@en .

epr:CentreManager
    a owl:Class ;
    rdfs:label "Centre manager"@en ;
    rdfs:comment "The named manager of a children's centre. Distinct from HeadteacherOrPrincipal — children's centres show the Centre manager role rather than Headteacher/Principal in the GIAS Details view."@en .


