#################################################################
# Classes — establishment groups (v1.1)
#################################################################

epr:EstablishmentGroup
    a owl:Class ;
    rdfs:label "Establishment group"@en ;
    rdfs:comment "An organisation or governance structure to which one or more establishments belong. Covers academy trusts, federations, school sponsors and children's centre groups. Distinct from the accountability relationship, which records legal/governance responsibility. Academy trusts are both establishment groups and accountability bodies — see epr:AcademyTrust."@en .

epr:MultiAcademyTrust
    a owl:Class ;
    rdfs:subClassOf epr:AcademyTrust ;
    rdfs:label "Multi-academy trust"@en ;
    rdfs:comment "A single legal academy-trust entity operating two or more academies, free schools, UTCs or studio schools. It has a master funding agreement with the Secretary of State and a supplemental funding agreement for each individual academy. Incorporated under the Companies Act 2006. Governed by a board of trustees. Source: GOV.UK academy trust governance guide."@en .

epr:SecureSingleAcademyTrust
    a owl:Class ;
    rdfs:subClassOf epr:SingleAcademyTrust ;
    rdfs:label "Secure single-academy trust"@en ;
    rdfs:comment "A single-academy trust operating a secure 16-to-19 academy providing education within secure residential accommodation for young people aged 16 to 19 subject to a custodial sentence or secure order."@en .

epr:Federation
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Federation"@en ;
    rdfs:comment "A statutory arrangement in which two or more maintained schools, including maintained nursery schools, share a single federated governing body. Each member school retains its own URN, establishment number, admissions arrangements and Ofsted inspection identity. Some governance and funding arrangements may be shared or pooled under federation rules. Applicable only to maintained schools. Source: School Governance (Federations) Regulations 2012."@en .

epr:SchoolSponsor
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "School sponsor"@en ;
    rdfs:comment "A body approved by the Secretary of State to sponsor one or more sponsor-led academies or free schools. Supports governance, leadership and educational improvement. Source: Academies Act 2010."@en .

epr:ChildrensCentreGroup
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Children's centres group"@en ;
    rdfs:comment "An operational cluster of children's centres with a lead-centre arrangement."@en .

epr:ChildrensCentreCollaboration
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Children's centres collaboration"@en ;
    rdfs:comment "A cross-group collaboration arrangement between children's centres."@en .

epr:GenericTrust
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Trust"@en ;
    rdfs:comment "A generic trust group type (EstablishmentGroupType code 02). Distinct from AcademyTrust. Rarely used in current data; retained for completeness."@en .

epr:GroupMembership
    a owl:Class ;
    rdfs:label "Group membership"@en ;
    rdfs:comment "A dated record of an establishment's membership of an establishment group, trust, federation, sponsor arrangement or children's centre collaboration. Maps to GroupLink in the current GIAS schema. An establishment may have membership in more than one group simultaneously."@en .

epr:GroupRelationship
    a owl:Class ;
    rdfs:label "Group relationship"@en ;
    rdfs:comment "A recorded relationship between two establishment groups, for example where a single-academy trust is the predecessor to a newly formed multi-academy trust. Maps to GroupRelationsLink."@en .

epr:GroupRelationshipType
    a owl:Class ;
    rdfs:label "Group relationship type"@en ;
    rdfs:comment "The classification of a group-to-group relationship, for example predecessor SAT or successor MAT."@en .

epr:GroupId
    a owl:Class ;
    rdfs:label "Group identifier"@en ;
    rdfs:comment "The business-facing GIAS group identifier, distinct from the internal surrogate key."@en .

epr:GroupUkprn
    a owl:Class ;
    rdfs:label "Group UKPRN"@en ;
    rdfs:comment "A UKRLP provider reference number assigned to the group organisation. Sourced from UKRLP by matching on Companies House number."@en .

#################################################################
# Named individuals — closed enumeration values (v0.8, v1.0)
#
# Classification values for closed, stable enumerations that
# carry semantic weight. Declared as owl:NamedIndividual so they
# appear in WebVOWL and support OWL reasoning.
#
# Open-ended value sets (ReligiousCharacter, ReligiousEthos,
# TypeOfSenProvision, establishment type codes) remain as
# skos:Concept in the vocabulary TTL only.
#

# Identifier role (2 values, v1.0)
epr:CurrentIdentifierRole
    a owl:NamedIndividual, epr:IdentifierRole ;
    rdfs:label "Current"@en .

epr:PreviousIdentifierRole
    a owl:NamedIndividual, epr:IdentifierRole ;
    rdfs:label "Previous"@en .

# Group relationship type (2 values, v1.1)
epr:SuccessorMultiAcademyTrust
    a owl:NamedIndividual, epr:GroupRelationshipType ;
    rdfs:label "Successor MAT"@en .

epr:PredecessorSingleAcademyTrust
    a owl:NamedIndividual, epr:GroupRelationshipType ;
    rdfs:label "Predecessor SAT"@en .
# The same epr: URIs also carry skos:Concept in the vocabulary
# TTL — valid OWL 2 punning.
#################################################################

# Establishment status (4 values)
epr:OpenStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Open"@en .

epr:ClosedStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Closed"@en .

epr:OpenProposedToCloseStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Open, but proposed to close"@en .

epr:ProposedToOpenStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Proposed to open"@en .

# Education phase (8 values)
epr:NurseryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Nursery"@en .

epr:PrimaryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Primary"@en .

epr:MiddlePhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Middle deemed primary"@en .

epr:MiddleDeemedSecondaryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Middle deemed secondary"@en .

epr:SecondaryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Secondary"@en .

epr:AllThroughPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "All-through"@en .

epr:SixteenToNineteenPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "16 to 19"@en .

epr:NotApplicableEducationPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Not applicable (education phase)"@en .

# Admissions policy (3 values)
epr:SelectiveAdmissions
    a owl:NamedIndividual, epr:AdmissionsPolicy ;
    rdfs:label "Selective"@en .

epr:NonSelectiveAdmissions
    a owl:NamedIndividual, epr:AdmissionsPolicy ;
    rdfs:label "Non-selective"@en .

epr:NotApplicableAdmissionsPolicy
    a owl:NamedIndividual, epr:AdmissionsPolicy ;
    rdfs:label "Not applicable (admissions policy)"@en .

# Gender of entry (4 values)
epr:BoysOnlyGenderEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Boys"@en .

epr:GirlsOnlyGenderEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Girls"@en .

epr:MixedGenderEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Mixed"@en .

epr:NotApplicableGenderOfEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Not applicable (gender of entry)"@en .

# Boarding provision (3 values)
epr:BoardingSchool
    a owl:NamedIndividual, epr:BoardingProvision ;
    rdfs:label "Boarding school"@en .

epr:HasBoarders
    a owl:NamedIndividual, epr:BoardingProvision ;
    rdfs:label "Has boarders"@en .

epr:NoBoarders
    a owl:NamedIndividual, epr:BoardingProvision ;
    rdfs:label "No boarders"@en .

# Nursery provision (3 values)
epr:HasNurseryClasses
    a owl:NamedIndividual, epr:NurseryProvision ;
    rdfs:label "Has nursery classes"@en .

epr:NoNurseryClasses
    a owl:NamedIndividual, epr:NurseryProvision ;
    rdfs:label "No nursery classes"@en .

epr:NotApplicableNurseryProvision
    a owl:NamedIndividual, epr:NurseryProvision ;
