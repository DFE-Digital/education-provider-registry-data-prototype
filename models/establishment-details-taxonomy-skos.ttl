@prefix gias: <https://education.gov.uk/gias/vocabulary/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# GIAS 2.0 Establishment Details Taxonomy — full-scope version
#
# This is an expanded version of:
# docs/transformation/data/modelling/establishment-details-taxonomy-skos.ttl
#
# The prior version was scoped to three worked examples (academy converter,
# community school, other independent school). This version covers all 46
# establishment types defined in the ERD, including the five archived types
# that have no rows in current extracts.
#
# All 46 establishment types are represented as taxons under EstablishmentType,
# with an intermediate type-group level following the ERD group codes.
#
# Facets are represented as top concepts. Taxons are narrower concepts beneath
# their facet. Dates, identifiers, measures and organisation relationships are
# excluded because they are not taxonomy classifications.
#
# Evidenced by:
#   docs/data/extract-data/establishment-fields/establishment-type-analysis.md
#   docs/data/extract-data/establishment-fields/establishment-details-tab-fields-by-type.md
#
# Maintained in: docs/transformation/data/modelling/claude/

gias:status
    a rdf:Property ;
    rdfs:label "Vocabulary status"@en ;
    rdfs:comment "The review status assigned to a concept in the working GIAS 2.0 vocabulary or taxonomy."@en .

gias:establishmentDetailsTaxonomy
    a skos:ConceptScheme ;
    dcterms:title "GIAS 2.0 Establishment Details Taxonomy"@en ;
    dcterms:description "Faceted taxonomy containing classifications for the Establishment Details public tab, expanded to cover all 46 establishment types and all classification facets observed across the full type range."@en ;
    dcterms:created "2026-06-16"^^xsd:date ;
    gias:status "Provisional"@en ;
    skos:hasTopConcept
        gias:EstablishmentType,
        gias:EducationPhase,
        gias:EstablishmentStatus,
        gias:AdmissionsPolicy,
        gias:GenderOfEntry,
        gias:BoardingProvision,
        gias:NurseryProvision,
        gias:SixthFormProvision,
        gias:SpecialClassProvision,
        gias:ReligiousCharacter,
        gias:ReligiousEthos .

#################################################################
# Facet collection
#################################################################

gias:establishmentDetailsTaxonomyFacets
    a skos:Collection ;
    skos:prefLabel "Establishment Details taxonomy facets"@en ;
    skos:member
        gias:EstablishmentType,
        gias:EducationPhase,
        gias:EstablishmentStatus,
        gias:AdmissionsPolicy,
        gias:GenderOfEntry,
        gias:BoardingProvision,
        gias:NurseryProvision,
        gias:SixthFormProvision,
        gias:SpecialClassProvision,
        gias:ReligiousCharacter,
        gias:ReligiousEthos .

#################################################################
# Type-group collection
#################################################################

gias:establishmentTypeGroups
    a skos:Collection ;
    skos:prefLabel "Establishment type groups"@en ;
    skos:member
        gias:EstablishmentTypeGroupColleges,
        gias:EstablishmentTypeGroupUniversities,
        gias:EstablishmentTypeGroupIndependentSchools,
        gias:EstablishmentTypeGroupLaMaintainedSchools,
        gias:EstablishmentTypeGroupNonMaintainedSpecialSchools,
        gias:EstablishmentTypeGroupWelshEstablishments,
        gias:EstablishmentTypeGroupOtherTypes,
        gias:EstablishmentTypeGroupAcademies,
        gias:EstablishmentTypeGroupFreeSchools,
        gias:EstablishmentTypeGroupChildrensCentres,
        gias:EstablishmentTypeGroupOnlineProviders .

#################################################################
# Facets
#################################################################

gias:EstablishmentType
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Establishment type"@en ;
    skos:definition "The legal, operational or policy classification recorded as the establishment's type."@en ;
    skos:scopeNote "This remains an overloaded legacy classification mixing legal form, sector and operational model. The intermediate type-group level follows ERD group codes."@en ;
    gias:status "Provisional"@en .

gias:EducationPhase
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Education phase"@en ;
    skos:definition "The broad stage of education provided by an establishment."@en ;
    gias:status "Provisional"@en .

gias:EstablishmentStatus
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Establishment status"@en ;
    skos:definition "The current lifecycle or operating-state classification of an establishment."@en ;
    gias:status "Provisional"@en .

gias:AdmissionsPolicy
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Admissions policy"@en ;
    skos:definition "The classification describing how places are allocated."@en ;
    gias:status "Provisional"@en .

gias:GenderOfEntry
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Gender of entry"@en ;
    skos:definition "The classification describing the establishment's gender admission arrangement."@en ;
    gias:status "Provisional"@en .

gias:BoardingProvision
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Boarding provision"@en ;
    skos:definition "The classification describing whether boarding places are offered."@en ;
    gias:status "Provisional"@en .

gias:NurseryProvision
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Nursery provision"@en ;
    skos:definition "The classification describing whether the establishment offers nursery classes."@en ;
    gias:status "Provisional"@en .

gias:SixthFormProvision
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Sixth-form provision"@en ;
    skos:definition "The classification describing whether the establishment has a sixth form."@en ;
    gias:status "Provisional"@en .

gias:SpecialClassProvision
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Special-class provision"@en ;
    skos:definition "The classification describing whether the establishment has special classes."@en ;
    gias:status "Provisional"@en .

gias:ReligiousCharacter
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Religious character"@en ;
    skos:definition "The formal religious-character classification designated for an establishment."@en ;
    gias:status "Provisional"@en .

gias:ReligiousEthos
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:topConceptOf gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Religious ethos"@en ;
    skos:definition "The recorded religious-ethos classification associated with an establishment."@en ;
    skos:scopeNote "Its distinction from religious character requires business validation."@en ;
    gias:status "Provisional"@en .

#################################################################
# Establishment type groups (ERD group codes)
#################################################################

gias:EstablishmentTypeGroupColleges
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Colleges"@en ;
    skos:altLabel "Further education colleges"@en ;
    skos:definition "The GIAS establishment type group covering further and sixth-form education colleges (ERD group code 1)."@en ;
    skos:broader gias:EstablishmentType ;
    skos:narrower
        gias:FurtherEducation,
        gias:SixthFormCentre ;
    gias:status "Provisional"@en .

gias:EstablishmentTypeGroupUniversities
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Universities and higher education"@en ;
