    skos:narrower
        gias:CommunitySchool,
        gias:VoluntaryAidedSchool,
        gias:VoluntaryControlledSchool,
        gias:FoundationSchool,
        gias:CommunitySpecialSchool,
        gias:FoundationSpecialSchool,
        gias:PupilReferralUnit,
        gias:LocalAuthorityNurserySchool ;
    gias:status "Provisional"@en .

gias:EstablishmentTypeGroupNonMaintainedSpecialSchools
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Non-maintained special schools"@en ;
    skos:definition "The GIAS establishment type group covering non-maintained and independent special schools (ERD group code 5)."@en ;
    skos:broader gias:EstablishmentType ;
    skos:narrower
        gias:NonMaintainedSpecialSchool,
        gias:IndependentSchoolApprovedForSenPupils,
        gias:OtherIndependentSpecialSchool ;
    gias:status "Provisional"@en .

gias:EstablishmentTypeGroupWelshEstablishments
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Welsh establishments"@en ;
