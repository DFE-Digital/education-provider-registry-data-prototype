    skos:definition "The GIAS establishment type group covering higher education institutions (ERD group code 2)."@en ;
    skos:broader gias:EstablishmentType ;
    skos:narrower
        gias:HigherEducationInstitution ;
    gias:status "Provisional"@en .

gias:EstablishmentTypeGroupIndependentSchools
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Independent schools"@en ;
