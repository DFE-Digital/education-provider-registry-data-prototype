    skos:narrower
        gias:WelshEstablishment ;
    gias:status "Provisional"@en .

gias:EstablishmentTypeGroupOtherTypes
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsTaxonomy ;
    skos:prefLabel "Other types"@en ;
    skos:altLabel "Miscellaneous"@en ;
    skos:definition "The GIAS establishment type group covering miscellaneous and other establishment types (ERD group code 9)."@en ;
    skos:broader gias:EstablishmentType ;
    skos:narrower
        gias:EuropeanSchools,
        gias:EarlyYearsSetting,
        gias:PlayingForSuccessCentres,
        gias:SecureUnits,
        gias:OffshoreSchools,
