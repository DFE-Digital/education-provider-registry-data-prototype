    skos:altLabel "Number of special pupils not under a SEN statement/EHC plan"@en, "SENNoStat"@en ;
    skos:definition "The number of special pupils who are not the subject of a special educational needs statement or an education, health and care plan."@en ;
    skos:broader epr:CapacityAndPupilMeasures ;
    skos:related epr:SpecialPupilsOnStatementOrEhcPlan ;
    epr:status "Provisional"@en ;
    dcterms:source "Database field: SENNoStat"@en .

