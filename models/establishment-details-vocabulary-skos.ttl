    gias:status "Preferred"@en ;
    dcterms:source "C#: CloseDate; Java: closeDate; database: Establishment.CloseDate"@en .

gias:ReasonEstablishmentClosed
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Reason establishment closed"@en ;
    skos:definition "The classification explaining why the establishment closed."@en ;
    skos:broader gias:EstablishmentLifecycle ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: ReasonEstablishmentClosedId; Java: reasonEstablishmentClosed; database: Establishment.reasonEstablishmentClosed_code"@en .

#################################################################
# Record currency and stewardship
#################################################################

gias:DateLastChangedOrConfirmed
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Date last changed or confirmed"@en ;
    skos:altLabel "Date last changed/confirmed"@en, "Last Changed Date"@en ;
    skos:definition "The most recent date on which the establishment record was changed or confirmed as accurate."@en ;
    skos:scopeNote "Describes the currency and confirmation of the GIAS record rather than the lifecycle of the real-world establishment. It may combine two different business events and requires further analysis."@en ;
    skos:broader gias:RecordCurrencyAndStewardship ;
    gias:status "Provisional"@en ;
