@prefix epr: <https://dfe-digital.github.io/education-provider-registry-data/vocabulary/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# GIAS 2.0 Establishment Details Vocabulary
#
# Scope: this version covers the fields shown in the Establishment Details
# table in the public establishment record view.
#
# It defines business vocabulary for those displayed detail fields, including
# field concepts, labels, aliases, definitions, relationships, review statuses
# and source notes. It is not a complete provider-domain ontology and does not
# attempt to model fields outside the Establishment Details table.
#
# Canonical concept identifiers are the expanded epr: IRIs, for example
# epr:EstablishmentLifecycle expands to:
# https://dfe-digital.github.io/education-provider-registry-data/vocabulary/EstablishmentLifecycle/
#
# The namespace is published through the GitHub Pages documentation site and provides persistent, resolvable concept URIs.

epr:status
    a rdf:Property ;
    rdfs:label "Vocabulary status"@en ;
    rdfs:comment "The review status assigned to a concept in the working GIAS 2.0 vocabulary."@en .

epr:establishmentDetailsVocabulary
    a skos:ConceptScheme ;
    dcterms:title "GIAS 2.0 Establishment Details Vocabulary"@en ;
    dcterms:description "Controlled vocabulary for the GIAS 2.0 data-modelling work, scoped to the fields shown in the Establishment Details table in the public establishment record view."@en ;
    dcterms:created "2026-06-16"^^xsd:date ;
    epr:status "Provisional"@en ;
    skos:hasTopConcept
        epr:Establishment,
        epr:EstablishmentIdentity,
        epr:EstablishmentClassification,
        epr:EstablishmentAccountability,
        epr:EstablishmentLifecycle,
        epr:RecordCurrencyAndStewardship,
        epr:EstablishmentLocationAndContact,
        epr:EstablishmentLeadership,
        epr:EducationAdmissionsAndProvision,
        epr:CapacityAndPupilMeasures,
        epr:FaithContext,
        epr:SenAndResourcedProvision,
        epr:AlternativeProvisionCharacteristics,
        epr:InspectionRecord,
        epr:AccreditationAndQualityAssurance,
        epr:ExternalReference .

#################################################################
# Thematic collections
#################################################################

epr:coreConcepts
    a skos:Collection ;
    skos:prefLabel "Core concepts"@en ;
    skos:member
        epr:Establishment,
        epr:EstablishmentDetails,
        epr:EstablishmentType,
        epr:EstablishmentTypeGroup,
        epr:AcademyConverter,
        epr:CommunitySchool,
        epr:OtherIndependentSchool .

epr:identityAndIdentifiers
    a skos:Collection ;
    skos:prefLabel "Identity and identifiers"@en ;
    skos:member
        epr:EstablishmentName,
        epr:UniqueReferenceNumber,
        epr:EstablishmentNumber,
        epr:DfeNumber,
        epr:Laestab,
        epr:UkProviderReferenceNumber,
        epr:FeHeIdentifier .

epr:classificationAndAccountability
    a skos:Collection ;
    skos:prefLabel "Classification and accountability"@en ;
    skos:member
        epr:EducationPhase,
        epr:FurtherEducationType,
        epr:ProviderType,
        epr:LocalAuthority,
        epr:MaintainingAuthority,
        epr:AcademyTrust,
        epr:SingleAcademyTrust,
        epr:AcademySponsor,
        epr:Proprietor .

epr:lifecycle
    a skos:Collection ;
    skos:prefLabel "Lifecycle"@en ;
    skos:member
        epr:EstablishmentStatus,
        epr:OpenStatus,
        epr:ClosedStatus,
        epr:OpenProposedToCloseStatus,
        epr:ProposedToOpenStatus,
        epr:OpenDate,
        epr:ReasonEstablishmentOpened,
        epr:ClosedDate,
        epr:ReasonEstablishmentClosed .

epr:recordCurrencyAndStewardship
    a skos:Collection ;
    skos:prefLabel "Record currency and stewardship"@en ;
    skos:member
        epr:DateLastChangedOrConfirmed .

epr:locationAndContact
    a skos:Collection ;
    skos:prefLabel "Location and contact"@en ;
    skos:member
        epr:MainAddress,
        epr:Website,
        epr:TelephoneNumber,
        epr:UniquePropertyReferenceNumber .

epr:leadership
    a skos:Collection ;
    skos:prefLabel "Leadership"@en ;
    skos:member
        epr:HeadteacherOrPrincipal,
        epr:CentreManager,
        epr:PreferredJobTitle .

epr:educationAdmissionsAndProvision
    a skos:Collection ;
    skos:prefLabel "Education, admissions and provision"@en ;
    skos:member
        epr:StatutoryAgeRange,
        epr:GenderOfEntry,
        epr:AdmissionsPolicy,
        epr:BoardingProvision,
        epr:NurseryProvision,
        epr:SixthFormProvision,
        epr:SpecialClassProvision,
        epr:Section41Approval .

epr:capacityAndPupilMeasures
    a skos:Collection ;
    skos:prefLabel "Capacity and pupil measures"@en ;
    skos:member
        epr:SchoolCapacity,
        epr:PupilCount,
        epr:CensusDate,
        epr:PupilsEligibleForFreeSchoolMeals,
        epr:PercentagePupilsEligibleForFreeSchoolMeals,
        epr:SpecialPupilsOnStatementOrEhcPlan,
        epr:SpecialPupilsNotOnStatementOrEhcPlan .

epr:faithContext
    a skos:Collection ;
    skos:prefLabel "Faith context"@en ;
    skos:member
        epr:ReligiousCharacter,
        epr:ReligiousEthos,
        epr:Diocese .

epr:senAndResourcedProvision
    a skos:Collection ;
    skos:prefLabel "SEN and resourced provision"@en ;
    skos:member
        epr:TypeOfSenProvision,
        epr:TypeOfResourcedProvision,
        epr:ResourcedProvisionPupilCount,
        epr:ResourcedProvisionCapacity,
        epr:SenUnitPupilCount,
        epr:SenUnitCapacity .

epr:alternativeProvisionCharacteristics
    a skos:Collection ;
    skos:prefLabel "Alternative provision characteristics"@en ;
    skos:member
        epr:TeenageMothersProvision,
        epr:TeenageMothersPlaces,
        epr:ChildcareFacilitiesProvision,
        epr:SenFacilitiesProvision,
        epr:EbdPupilsProvision,
        epr:AlternativeProvisionPlaces,
        epr:FullTimeProvision,
        epr:PupilsEducatedByOtherProviders .

epr:inspectionRecord
    a skos:Collection ;
    skos:prefLabel "Inspection record"@en ;
    skos:member
        epr:InspectorateName,
        epr:InspectorateReport,
        epr:DateOfLastInspectionVisit,
        epr:DateOfNextInspectionVisit .

epr:accreditationAndQualityAssurance
    a skos:Collection ;
    skos:prefLabel "Accreditation and quality assurance"@en ;
    skos:member
        epr:AccreditationDate,
        epr:AccreditationExpiryDate,
        epr:AccreditationDateEnded,
        epr:QualityAssuranceBodyName,
        epr:QualityAssuranceBodyReport,
        epr:CompaniesHouseNumber,
        epr:EstablishmentAccredited .

epr:externalReferences
    a skos:Collection ;
    skos:prefLabel "External references"@en ;
    skos:member
        epr:InspectionReportReference,
        epr:ExternalServiceReference .

#################################################################
# Top concepts
#################################################################

epr:Establishment
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment"@en ;
    skos:altLabel "Establishments"@en ;
    skos:definition "A registered education establishment recorded by GIAS, such as a school, college, children's centre or other education provider."@en ;
    skos:scopeNote "Do not use school as a universal synonym because GIAS includes non-school establishments."@en ;
    skos:narrower
        epr:EstablishmentDetails ;
    epr:status "Preferred"@en .

epr:EstablishmentIdentity
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment identity"@en ;
    skos:definition "The names and identifiers used to distinguish and refer to an establishment."@en ;
    skos:narrower
        epr:DfeNumber,
        epr:EstablishmentName,
        epr:EstablishmentNumber,
        epr:FeHeIdentifier,
        epr:Laestab,
        epr:UkProviderReferenceNumber,
        epr:UniqueReferenceNumber ;
    epr:status "Provisional"@en .

epr:EstablishmentClassification
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment classification"@en ;
    skos:definition "The controlled classifications used to describe an establishment."@en ;
    skos:narrower
        epr:EducationPhase,
        epr:EstablishmentType,
        epr:EstablishmentTypeGroup,
        epr:FurtherEducationType,
        epr:ProviderType ;
    epr:status "Provisional"@en .

epr:EstablishmentAccountability
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment accountability"@en ;
    skos:definition "The organisations or people responsible for maintaining, operating or being accountable for an establishment."@en ;
    skos:narrower
        epr:AcademySponsor,
        epr:AcademyTrust,
        epr:LocalAuthority,
        epr:MaintainingAuthority,
        epr:Proprietor ;
    epr:status "Provisional"@en .

epr:EstablishmentLifecycle
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment lifecycle"@en ;
    skos:definition "The states, dates and reasons that describe the opening, operation and closure of an establishment."@en ;
    skos:narrower
        epr:ClosedDate,
        epr:EstablishmentStatus,
        epr:OpenDate,
        epr:ReasonEstablishmentClosed,
        epr:ReasonEstablishmentOpened ;
    epr:status "Provisional"@en .

epr:RecordCurrencyAndStewardship
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Record currency and stewardship"@en ;
    skos:definition "Information describing when an establishment record was changed, reviewed or confirmed as accurate."@en ;
    skos:narrower
        epr:DateLastChangedOrConfirmed ;
    epr:status "Provisional"@en .

epr:EstablishmentLocationAndContact
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment location and contact"@en ;
    skos:definition "The location identifiers, postal address and published contact information for an establishment."@en ;
    skos:narrower
        epr:MainAddress,
        epr:TelephoneNumber,
        epr:UniquePropertyReferenceNumber,
        epr:Website ;
    epr:status "Provisional"@en .

epr:EstablishmentLeadership
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment leadership"@en ;
    skos:definition "The principal education leadership information presented for an establishment."@en ;
    skos:narrower
        epr:CentreManager,
        epr:HeadteacherOrPrincipal,
        epr:PreferredJobTitle ;
    epr:status "Provisional"@en .

epr:EducationAdmissionsAndProvision
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Education, admissions and provision"@en ;
    skos:definition "The classifications and characteristics describing the education, admissions arrangements and provision offered by an establishment."@en ;
    skos:narrower
        epr:AdmissionsPolicy,
        epr:BoardingProvision,
        epr:GenderOfEntry,
        epr:NurseryProvision,
        epr:Section41Approval,
        epr:SixthFormProvision,
        epr:SpecialClassProvision,
        epr:StatutoryAgeRange ;
    epr:status "Provisional"@en .

epr:CapacityAndPupilMeasures
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Capacity and pupil measures"@en ;
    skos:definition "Measures describing establishment capacity and pupil populations at an effective date."@en ;
    skos:narrower
        epr:CensusDate,
        epr:PercentagePupilsEligibleForFreeSchoolMeals,
        epr:PupilCount,
        epr:PupilsEligibleForFreeSchoolMeals,
        epr:SchoolCapacity,
