@prefix gias: <https://education.gov.uk/gias/vocabulary/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# GIAS 2.0 Establishment Details Vocabulary — full-scope version
#
# This is an expanded version of:
# docs/transformation/data/modelling/establishment-details-vocabulary-skos.ttl
#
# Scope: all fields shown on the public Establishment Details tab across all
# observed establishment types, evidenced by:
#   docs/data/extract-data/establishment-fields/establishment-details-tab-fields-by-type.md
#   docs/data/extract-data/establishment-fields/establishment-type-analysis.md
#
# The prior version was scoped to three worked examples (academy converter,
# community school, other independent school). This version covers all 41
# observed establishment types and adds concept groups for alternative provision,
# inspection records, and online-provider accreditation.
#
# The namespace is a proposed identifier and does not imply a published service.
# Maintained in: docs/transformation/data/modelling/claude/

gias:status
    a rdf:Property ;
    rdfs:label "Vocabulary status"@en ;
    rdfs:comment "The review status assigned to a concept in the working GIAS 2.0 vocabulary."@en .

gias:establishmentDetailsVocabulary
    a skos:ConceptScheme ;
    dcterms:title "GIAS 2.0 Establishment Details Vocabulary"@en ;
    dcterms:description "Controlled vocabulary for the GIAS 2.0 data-modelling work, scoped to all fields shown on the public Establishment Details tab across all 46 establishment types defined in the GIAS extract."@en ;
    dcterms:created "2026-06-16"^^xsd:date ;
    gias:status "Provisional"@en ;
    skos:hasTopConcept
        gias:Establishment,
        gias:EstablishmentIdentity,
        gias:EstablishmentClassification,
        gias:EstablishmentAccountability,
        gias:EstablishmentLifecycle,
        gias:RecordCurrencyAndStewardship,
        gias:EstablishmentLocationAndContact,
        gias:EstablishmentLeadership,
        gias:EducationAdmissionsAndProvision,
        gias:CapacityAndPupilMeasures,
        gias:FaithContext,
        gias:SenAndResourcedProvision,
        gias:AlternativeProvisionCharacteristics,
        gias:InspectionRecord,
        gias:AccreditationAndQualityAssurance,
        gias:ExternalReference .

#################################################################
# Thematic collections
#################################################################

gias:coreConcepts
    a skos:Collection ;
    skos:prefLabel "Core concepts"@en ;
    skos:member
        gias:Establishment,
        gias:EstablishmentDetails,
        gias:EstablishmentType,
        gias:EstablishmentTypeGroup,
        gias:AcademyConverter,
        gias:CommunitySchool,
        gias:OtherIndependentSchool .

gias:identityAndIdentifiers
    a skos:Collection ;
    skos:prefLabel "Identity and identifiers"@en ;
    skos:member
        gias:EstablishmentName,
        gias:UniqueReferenceNumber,
        gias:EstablishmentNumber,
        gias:DfeNumber,
        gias:Laestab,
        gias:UkProviderReferenceNumber,
        gias:FeHeIdentifier .

gias:classificationAndAccountability
    a skos:Collection ;
    skos:prefLabel "Classification and accountability"@en ;
    skos:member
        gias:EducationPhase,
        gias:FurtherEducationType,
        gias:ProviderType,
        gias:LocalAuthority,
        gias:MaintainingAuthority,
        gias:AcademyTrust,
        gias:SingleAcademyTrust,
        gias:AcademySponsor,
        gias:Proprietor .

gias:lifecycle
    a skos:Collection ;
    skos:prefLabel "Lifecycle"@en ;
    skos:member
        gias:EstablishmentStatus,
        gias:OpenDate,
        gias:ReasonEstablishmentOpened,
        gias:ClosedDate,
        gias:ReasonEstablishmentClosed .

gias:recordCurrencyAndStewardship
    a skos:Collection ;
    skos:prefLabel "Record currency and stewardship"@en ;
    skos:member
        gias:DateLastChangedOrConfirmed .

gias:locationAndContact
    a skos:Collection ;
    skos:prefLabel "Location and contact"@en ;
    skos:member
        gias:MainAddress,
        gias:Website,
        gias:TelephoneNumber,
        gias:UniquePropertyReferenceNumber .

gias:leadership
    a skos:Collection ;
    skos:prefLabel "Leadership"@en ;
    skos:member
        gias:HeadteacherOrPrincipal,
        gias:CentreManager,
        gias:PreferredJobTitle .

gias:educationAdmissionsAndProvision
    a skos:Collection ;
    skos:prefLabel "Education, admissions and provision"@en ;
    skos:member
        gias:StatutoryAgeRange,
        gias:GenderOfEntry,
        gias:AdmissionsPolicy,
        gias:BoardingProvision,
        gias:NurseryProvision,
        gias:SixthFormProvision,
        gias:SpecialClassProvision,
        gias:Section41Approval .

gias:capacityAndPupilMeasures
    a skos:Collection ;
    skos:prefLabel "Capacity and pupil measures"@en ;
    skos:member
        gias:SchoolCapacity,
        gias:PupilCount,
        gias:CensusDate,
        gias:PupilsEligibleForFreeSchoolMeals,
        gias:PercentagePupilsEligibleForFreeSchoolMeals,
        gias:SpecialPupilsOnStatementOrEhcPlan,
        gias:SpecialPupilsNotOnStatementOrEhcPlan .

gias:faithContext
    a skos:Collection ;
    skos:prefLabel "Faith context"@en ;
    skos:member
        gias:ReligiousCharacter,
        gias:ReligiousEthos,
        gias:Diocese .

gias:senAndResourcedProvision
    a skos:Collection ;
    skos:prefLabel "SEN and resourced provision"@en ;
    skos:member
        gias:TypeOfSenProvision,
        gias:TypeOfResourcedProvision,
        gias:ResourcedProvisionPupilCount,
        gias:ResourcedProvisionCapacity,
        gias:SenUnitPupilCount,
        gias:SenUnitCapacity .

gias:alternativeProvisionCharacteristics
    a skos:Collection ;
    skos:prefLabel "Alternative provision characteristics"@en ;
    skos:member
        gias:TeenageMothersProvision,
        gias:TeenageMothersPlaces,
        gias:ChildcareFacilitiesProvision,
        gias:SenFacilitiesProvision,
        gias:EbdPupilsProvision,
        gias:AlternativeProvisionPlaces,
        gias:FullTimeProvision,
        gias:PupilsEducatedByOtherProviders .

gias:inspectionRecord
    a skos:Collection ;
    skos:prefLabel "Inspection record"@en ;
    skos:member
        gias:InspectorateName,
        gias:InspectorateReport,
        gias:DateOfLastInspectionVisit,
        gias:DateOfNextInspectionVisit .

gias:accreditationAndQualityAssurance
    a skos:Collection ;
    skos:prefLabel "Accreditation and quality assurance"@en ;
    skos:member
        gias:AccreditationDate,
        gias:AccreditationExpiryDate,
        gias:AccreditationDateEnded,
        gias:QualityAssuranceBodyName,
        gias:QualityAssuranceBodyReport,
        gias:CompaniesHouseNumber,
        gias:EstablishmentAccredited .

gias:externalReferences
    a skos:Collection ;
    skos:prefLabel "External references"@en ;
    skos:member
        gias:InspectionReportReference,
        gias:ExternalServiceReference .

#################################################################
# Top concepts
#################################################################

gias:Establishment
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment"@en ;
    skos:altLabel "Establishments"@en ;
    skos:definition "A registered education establishment recorded by GIAS, such as a school, college, children's centre or other education provider."@en ;
    skos:scopeNote "Do not use school as a universal synonym because GIAS includes non-school establishments."@en ;
    gias:status "Preferred"@en .

gias:EstablishmentIdentity
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment identity"@en ;
    skos:definition "The names and identifiers used to distinguish and refer to an establishment."@en ;
    gias:status "Provisional"@en .

gias:EstablishmentClassification
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment classification"@en ;
    skos:definition "The controlled classifications used to describe an establishment."@en ;
    gias:status "Provisional"@en .

gias:EstablishmentAccountability
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment accountability"@en ;
    skos:definition "The organisations or people responsible for maintaining, operating or being accountable for an establishment."@en ;
    gias:status "Provisional"@en .

gias:EstablishmentLifecycle
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment lifecycle"@en ;
    skos:definition "The states, dates and reasons that describe the opening, operation and closure of an establishment."@en ;
    gias:status "Provisional"@en .

gias:RecordCurrencyAndStewardship
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Record currency and stewardship"@en ;
    skos:definition "Information describing when an establishment record was changed, reviewed or confirmed as accurate."@en ;
    gias:status "Provisional"@en .

gias:EstablishmentLocationAndContact
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment location and contact"@en ;
    skos:definition "The location identifiers, postal address and published contact information for an establishment."@en ;
    gias:status "Provisional"@en .

gias:EstablishmentLeadership
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment leadership"@en ;
    skos:definition "The principal education leadership information presented for an establishment."@en ;
    gias:status "Provisional"@en .

gias:EducationAdmissionsAndProvision
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Education, admissions and provision"@en ;
    skos:definition "The classifications and characteristics describing the education, admissions arrangements and provision offered by an establishment."@en ;
    gias:status "Provisional"@en .

gias:CapacityAndPupilMeasures
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Capacity and pupil measures"@en ;
    skos:definition "Measures describing establishment capacity and pupil populations at an effective date."@en ;
    gias:status "Provisional"@en .

gias:FaithContext
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Faith context"@en ;
    skos:definition "The religious-character, ethos and diocesan classifications associated with an establishment."@en ;
    gias:status "Provisional"@en .

gias:SenAndResourcedProvision
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "SEN and resourced provision"@en ;
    skos:definition "The special educational needs and resourced-provision classifications and measures associated with an establishment."@en ;
    gias:status "Provisional"@en .

gias:AlternativeProvisionCharacteristics
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Alternative provision characteristics"@en ;
    skos:definition "The provision indicators and pupil measures specific to pupil referral units and alternative provision establishments."@en ;
    skos:scopeNote "Shown on the Details tab for pupil referral units (type 14). Not applicable to mainstream or independent schools."@en ;
    gias:status "Provisional"@en .

gias:InspectionRecord
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Inspection record"@en ;
    skos:definition "Information about an establishment's inspectorate, inspection reports and inspection visit dates."@en ;
    skos:scopeNote "Shown for independent schools (inspectorate name only) and British schools overseas (inspectorate name, report and visit dates). Ofsted links appear under External reference rather than here."@en ;
    gias:status "Provisional"@en .

gias:AccreditationAndQualityAssurance
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Accreditation and quality assurance"@en ;
    skos:definition "The accreditation status, dates, quality assurance body details and related legal identifiers for online providers."@en ;
    skos:scopeNote "Applicable only to online providers (type 49). Accreditation date and accreditation date ended are type-49-specific presentations of the OpenDate and CloseDate fields."@en ;
    gias:status "Provisional"@en .

gias:ExternalReference
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:topConceptOf gias:establishmentDetailsVocabulary ;
    skos:prefLabel "External reference"@en ;
    skos:definition "A reference or link to related information owned and published by another service."@en ;
    gias:status "Provisional"@en .

#################################################################
# Core concepts
#################################################################

gias:EstablishmentDetails
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment details"@en ;
    skos:definition "The publicly presented descriptive information about an establishment."@en ;
    skos:scopeNote "A presentation grouping, not necessarily a single target-domain entity or aggregate."@en ;
    skos:broader gias:Establishment ;
    gias:status "Provisional"@en .

gias:EstablishmentType
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment type"@en ;
    skos:altLabel "School type"@en, "Type of Establishment"@en, "EstablishmentType"@en ;
    skos:definition "The current GIAS classification describing the operational or legal type of an establishment."@en ;
    skos:scopeNote "School type is too narrow for the wider registry. The current classification mixes several dimensions and requires further taxonomy analysis."@en ;
    skos:broader gias:EstablishmentClassification ;
    skos:related gias:EstablishmentTypeGroup ;
    gias:status "Preferred"@en ;
    dcterms:source "Database: Establishment.type_code -> EstablishmentType.code"@en .

gias:EstablishmentTypeGroup
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment type group"@en ;
    skos:altLabel "Establishment Type Group"@en, "EstablishmentTypeGroup"@en ;
    skos:definition "A broad grouping of establishment types, such as Academies, Local authority maintained schools or Independent schools."@en ;
    skos:broader gias:EstablishmentClassification ;
    skos:related gias:EstablishmentType ;
    gias:status "Preferred"@en .

gias:AcademyConverter
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Academy converter"@en ;
    skos:definition "An establishment type for a former school that converted to academy status."@en ;
    skos:scopeNote "An establishment type, not a trust type."@en ;
    skos:broader gias:EstablishmentType ;
    skos:related gias:AcademyTrust ;
    gias:status "Preferred"@en .

gias:CommunitySchool
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Community school"@en ;
    skos:definition "A local-authority-maintained establishment type where the local authority employs staff, owns land and buildings, and is the admissions authority."@en ;
    skos:broader gias:EstablishmentType ;
    skos:related gias:LocalAuthority, gias:MaintainingAuthority ;
    gias:status "Preferred"@en .

gias:OtherIndependentSchool
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Other independent school"@en ;
    skos:definition "An independent-school establishment type that is not the separately classified independent school approved for SEN pupils."@en ;
    skos:broader gias:EstablishmentType ;
    skos:related gias:Proprietor ;
    gias:status "Preferred"@en .

#################################################################
# Identity and identifiers
#################################################################

gias:EstablishmentName
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment name"@en ;
    skos:altLabel "Establishment Name"@en ;
    skos:definition "The registered name by which the establishment is identified and presented."@en ;
    skos:broader gias:EstablishmentIdentity ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: Name / EstablishmentName; Java: Establishment.name; database: Establishment.EstablishmentName"@en .

gias:UniqueReferenceNumber
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Unique Reference Number"@en ;
    skos:altLabel "URN"@en ;
    skos:definition "The unique sequential identifier assigned by GIAS when an establishment record is created."@en ;
    skos:broader gias:EstablishmentIdentity ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: Urn; Java: Establishment.urn; database: Establishment.URN"@en .

gias:EstablishmentNumber
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment number"@en ;
    skos:definition "A four-digit number used with the local-authority number to form the DfE number."@en ;
    skos:broader gias:EstablishmentIdentity ;
    skos:related gias:DfeNumber, gias:LocalAuthority ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: EstablishmentNumber; Java: establishmentNumber; database: Establishment.EstablishmentNumber"@en .

gias:DfeNumber
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "DfE number"@en ;
    skos:altLabel "Department for Education number"@en, "LAESTAB"@en ;
    skos:definition "A seven-digit identifier formed from the three-digit local-authority number and four-digit establishment number."@en ;
    skos:scopeNote "Derived rather than stored as one physical Establishment column."@en ;
    skos:broader gias:EstablishmentIdentity ;
    skos:related gias:EstablishmentNumber, gias:LocalAuthority, gias:Laestab ;
    gias:status "Preferred"@en .

gias:Laestab
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "LAESTAB"@en ;
    skos:altLabel "Local authority establishment"@en ;
    skos:definition "A legacy or common alias for the DfE number, formed from local-authority and establishment-number components."@en ;
    skos:scopeNote "Not a physical database column and not the preferred target term."@en ;
    skos:broader gias:EstablishmentIdentity ;
    skos:related gias:DfeNumber ;
    gias:status "Legacy alias"@en .

gias:UkProviderReferenceNumber
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "UK Provider Reference Number"@en ;
    skos:altLabel "UKPRN"@en ;
    skos:definition "An identifier issued by the UK Register of Learning Providers."@en ;
    skos:broader gias:EstablishmentIdentity ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: UKPRN; Java: ukprn; database: Establishment.UKPRN"@en .

gias:FeHeIdentifier
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "FE/HE identifier"@en ;
    skos:altLabel "FEHEIdentifier"@en ;
    skos:definition "A legacy identifier associated with further- or higher-education establishments."@en ;
    skos:broader gias:EstablishmentIdentity ;
    gias:status "Provisional"@en ;
    dcterms:source "Java: feheIdentifier; database: Establishment.FEHEIdentifier"@en .

#################################################################
# Classification
#################################################################

gias:EducationPhase
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Education phase"@en ;
    skos:altLabel "Phase of education"@en, "Phase of Education"@en ;
    skos:definition "The broad stage of education provided by the establishment, such as primary or secondary."@en ;
    skos:broader gias:EstablishmentClassification ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: EducationPhaseId; Java: educationPhase; database: Establishment.phaseOfEducation_code"@en .

gias:FurtherEducationType
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Further education type"@en ;
    skos:altLabel "FurtherEducationType"@en ;
    skos:definition "The classification describing the specific sub-type of further or higher education provision."@en ;
    skos:scopeNote "Shown on the Details tab for pupil referral units, further education establishments and higher education institutions."@en ;
    skos:broader gias:EstablishmentClassification ;
    gias:status "Provisional"@en ;
    dcterms:source "Database: Establishment.FurtherEducationType_code"@en .

gias:ProviderType
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Provider type"@en ;
    skos:definition "The classification describing the type of children's centre provider."@en ;
    skos:scopeNote "Shown on the Details tab for children's centres and children's centre linked sites in place of the school-type label used by other establishment types."@en ;
    skos:broader gias:EstablishmentClassification ;
    skos:related gias:EstablishmentType ;
    gias:status "Provisional"@en .

#################################################################
# Accountability
#################################################################

gias:LocalAuthority
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Local authority"@en ;
    skos:definition "The local government body providing administrative context and, for maintained schools, the maintaining authority."@en ;
    skos:broader gias:EstablishmentAccountability ;
    skos:related gias:MaintainingAuthority, gias:CommunitySchool ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: LocalAuthorityId; Java: officialGeoInfo.localAuthority; database: Establishment.LA_code -> LocalAuthority.code"@en .

gias:MaintainingAuthority
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Maintaining authority"@en ;
    skos:definition "The organisation legally responsible for maintaining a maintained school."@en ;
    skos:broader gias:EstablishmentAccountability ;
    skos:related gias:LocalAuthority, gias:CommunitySchool ;
    gias:status "Provisional"@en .

gias:AcademyTrust
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Academy trust"@en ;
    skos:altLabel "Trust"@en ;
    skos:definition "The legal organisation responsible for one or more academies."@en ;
    skos:scopeNote "Trust flag is an extract or implementation term, not the business concept."@en ;
    skos:broader gias:EstablishmentAccountability ;
    skos:related gias:AcademyConverter ;
    gias:status "Preferred"@en ;
    dcterms:source "Java/database: EstablishmentGroup and GroupLink"@en .

gias:SingleAcademyTrust
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Single-academy trust"@en ;
    skos:altLabel "Single academy trust"@en, "SAT"@en ;
    skos:definition "An academy trust responsible for a single academy."@en ;
    skos:broader gias:AcademyTrust ;
    gias:status "Preferred"@en .

gias:AcademySponsor
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Academy sponsor"@en ;
    skos:definition "An organisation or individual approved to sponsor an academy."@en ;
    skos:scopeNote "Shown on the Details tab for sponsor-led academies and several academy and free school types. Not shown for all academy types."@en ;
    skos:broader gias:EstablishmentAccountability ;
    skos:related gias:AcademyTrust ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: SchoolSponsors"@en .

gias:Proprietor
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Proprietor"@en ;
    skos:altLabel "Proprietor's name"@en ;
    skos:definition "The person or body that owns or operates an independent school or online provider."@en ;
    skos:broader gias:EstablishmentAccountability ;
    skos:related gias:OtherIndependentSchool ;
    gias:status "Preferred"@en ;
    dcterms:source "Database: IndependentSchools, EstablishmentProprietors; fields: PropsLastName and related Props* columns"@en .

#################################################################
# Lifecycle
#################################################################

gias:EstablishmentStatus
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment status"@en ;
    skos:definition "The current lifecycle or operating status of an establishment."@en ;
