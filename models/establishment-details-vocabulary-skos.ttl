    skos:scopeNote "Shown for independent special schools and online providers in place of the SEN provision type classification used by maintained schools."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    skos:related gias:SpecialPupilsNotOnStatementOrEhcPlan ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: SENStat"@en .

gias:SpecialPupilsNotOnStatementOrEhcPlan
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Special pupils not on a SEN statement or EHC plan"@en ;
    skos:altLabel "Number of special pupils not under a SEN statement/EHC plan"@en, "SENNoStat"@en ;
    skos:definition "The number of special pupils who are not the subject of a special educational needs statement or an education, health and care plan."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    skos:related gias:SpecialPupilsOnStatementOrEhcPlan ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: SENNoStat"@en .

