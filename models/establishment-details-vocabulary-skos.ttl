#################################################################

epr:HeadteacherOrPrincipal
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Headteacher or principal"@en ;
    skos:altLabel "Headteacher/Principal"@en, "Headteacher/Manager"@en ;
    skos:definition "The person presented as the establishment's principal education leader."@en ;
    skos:scopeNote "The UI label varies by establishment type. Schools show Headteacher / Principal. Online providers show Headteacher/Manager. Children's centres use the separate CentreManager concept."@en ;
    skos:broader epr:EstablishmentLeadership ;
    epr:status "Preferred"@en ;
    dcterms:source "C#/database fields: HeadTitle, HeadFirstName, HeadLastName and HeadPreferredJobTitle"@en .

epr:CentreManager
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Centre manager"@en ;
    skos:altLabel "Manager"@en ;
    skos:definition "The person presented as the manager of a children's centre."@en ;
    skos:scopeNote "Children's centres and children's centre linked sites display Manager rather than Headteacher or Principal. The underlying database fields are the same Head* fields used for other establishment types."@en ;
    skos:broader epr:EstablishmentLeadership ;
    skos:related epr:HeadteacherOrPrincipal ;
    epr:status "Provisional"@en .

epr:PreferredJobTitle
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Preferred job title"@en ;
    skos:altLabel "Headteacher Preferred Job Title"@en ;
    skos:definition "The title the establishment uses for its headteacher or principal role."@en ;
    skos:broader epr:EstablishmentLeadership ;
    skos:related epr:HeadteacherOrPrincipal ;
    epr:status "Preferred"@en .

#################################################################
