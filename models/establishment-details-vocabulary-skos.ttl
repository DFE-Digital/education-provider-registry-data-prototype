    epr:status "Provisional"@en .

epr:FaithContext
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Faith context"@en ;
    skos:definition "The religious-character, ethos and diocesan classifications associated with an establishment."@en ;
    skos:narrower
        epr:Diocese,
        epr:ReligiousCharacter,
        epr:ReligiousEthos ;
    epr:status "Provisional"@en .

epr:SenAndResourcedProvision
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "SEN and resourced provision"@en ;
    skos:definition "The special educational needs and resourced-provision classifications and measures associated with an establishment."@en ;
    skos:narrower
        epr:ResourcedProvisionCapacity,
        epr:ResourcedProvisionPupilCount,
        epr:SenUnitCapacity,
        epr:SenUnitPupilCount,
        epr:TypeOfResourcedProvision,
        epr:TypeOfSenProvision ;
    epr:status "Provisional"@en .

epr:AlternativeProvisionCharacteristics
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Alternative provision characteristics"@en ;
    skos:definition "The provision indicators and pupil measures specific to pupil referral units and alternative provision establishments."@en ;
    skos:scopeNote "Shown on the Details tab for pupil referral units (type 14). Not applicable to mainstream or independent schools."@en ;
    skos:narrower
        epr:AlternativeProvisionPlaces,
        epr:ChildcareFacilitiesProvision,
        epr:EbdPupilsProvision,
        epr:FullTimeProvision,
        epr:PupilsEducatedByOtherProviders,
        epr:SenFacilitiesProvision,
        epr:TeenageMothersPlaces,
        epr:TeenageMothersProvision ;
    epr:status "Provisional"@en .

epr:InspectionRecord
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Inspection record"@en ;
    skos:definition "Information about an establishment's inspectorate, inspection reports and inspection visit dates."@en ;
    skos:scopeNote "Shown for independent schools (inspectorate name only) and British schools overseas (inspectorate name, report and visit dates). Ofsted links appear under External reference rather than here."@en ;
    skos:narrower
        epr:DateOfLastInspectionVisit,
        epr:DateOfNextInspectionVisit,
        epr:InspectorateName,
        epr:InspectorateReport ;
    epr:status "Provisional"@en .

epr:AccreditationAndQualityAssurance
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Accreditation and quality assurance"@en ;
    skos:definition "The accreditation status, dates, quality assurance body details and related legal identifiers for online providers."@en ;
    skos:scopeNote "Applicable only to online providers (type 49). Accreditation date and accreditation date ended are type-49-specific presentations of the OpenDate and CloseDate fields."@en ;
    skos:narrower
        epr:AccreditationDate,
        epr:AccreditationDateEnded,
        epr:AccreditationExpiryDate,
        epr:CompaniesHouseNumber,
        epr:EstablishmentAccredited,
        epr:QualityAssuranceBodyName,
        epr:QualityAssuranceBodyReport ;
    epr:status "Provisional"@en .

epr:ExternalReference
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:topConceptOf epr:establishmentDetailsVocabulary ;
    skos:prefLabel "External reference"@en ;
    skos:definition "A reference or link to related information owned and published by another service."@en ;
    skos:narrower
        epr:ExternalServiceReference,
        epr:InspectionReportReference ;
    epr:status "Provisional"@en .

#################################################################
# Core concepts
#################################################################

epr:EstablishmentDetails
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment details"@en ;
    skos:definition "The publicly presented descriptive information about an establishment."@en ;
    skos:scopeNote "A presentation grouping, not necessarily a single target-domain entity or aggregate."@en ;
    skos:broader epr:Establishment ;
    epr:status "Provisional"@en .

epr:EstablishmentType
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment type"@en ;
    skos:altLabel "School type"@en, "Type of Establishment"@en, "EstablishmentType"@en ;
    skos:definition "The legal, operational or policy classification recorded as the establishment's type."@en ;
    skos:scopeNote "School type is too narrow for the wider registry. The classification mixes legal form, sector and operational model across a single dimension and requires further analysis."@en ;
    skos:broader epr:EstablishmentClassification ;
    skos:related epr:EstablishmentTypeGroup ;
    skos:narrower
        epr:EstablishmentTypeGroupAcademies,
        epr:EstablishmentTypeGroupChildrensCentres,
        epr:EstablishmentTypeGroupColleges,
        epr:EstablishmentTypeGroupFreeSchools,
        epr:EstablishmentTypeGroupIndependentSchools,
        epr:EstablishmentTypeGroupLaMaintainedSchools,
        epr:EstablishmentTypeGroupNonMaintainedSpecialSchools,
        epr:EstablishmentTypeGroupOnlineProviders,
        epr:EstablishmentTypeGroupOtherTypes,
        epr:EstablishmentTypeGroupUniversities,
        epr:EstablishmentTypeGroupWelshEstablishments ;
    epr:status "Preferred"@en ;
    dcterms:source "Database: Establishment.type_code -> EstablishmentType.code"@en .

epr:EstablishmentTypeGroup
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment type group"@en ;
    skos:altLabel "Establishment Type Group"@en, "EstablishmentTypeGroup"@en ;
    skos:definition "A broad grouping of establishment types, such as Academies, Local authority maintained schools or Independent schools."@en ;
    skos:broader epr:EstablishmentClassification ;
    skos:related epr:EstablishmentType ;
    epr:status "Preferred"@en .

epr:AcademyConverter
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Academy converter"@en ;
    skos:definition "An establishment type for a former school that converted to academy status."@en ;
    skos:scopeNote "An establishment type, not a trust type."@en ;
    skos:broader epr:EstablishmentTypeGroupAcademies ;
    skos:related epr:AcademyTrust ;
    epr:status "Preferred"@en .

epr:CommunitySchool
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Community school"@en ;
    skos:definition "A local-authority-maintained establishment type where the local authority employs staff, owns land and buildings, and is the admissions authority."@en ;
    skos:broader epr:EstablishmentTypeGroupLaMaintainedSchools ;
    skos:related epr:LocalAuthority, epr:MaintainingAuthority ;
    epr:status "Preferred"@en .

epr:OtherIndependentSchool
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Other independent school"@en ;
    skos:definition "An independent-school establishment type that is not the separately classified independent school approved for SEN pupils."@en ;
    skos:broader epr:EstablishmentTypeGroupIndependentSchools ;
    skos:related epr:Proprietor ;
    epr:status "Preferred"@en .

#################################################################
# Reviewed taxonomy value vocabulary concepts
#################################################################

epr:EstablishmentTypeGroupAcademies
    a skos:Concept ;
