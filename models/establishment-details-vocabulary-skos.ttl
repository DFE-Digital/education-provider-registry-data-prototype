    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Date of next inspection visit"@en ;
    skos:altLabel "Date of Next Inspection Visit"@en ;
    skos:definition "The scheduled date of the next inspection visit."@en ;
    skos:scopeNote "Shown for British schools overseas."@en ;
    skos:broader gias:InspectionRecord ;
    skos:related gias:DateOfLastInspectionVisit ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: NextInspectionVisit"@en .

#################################################################
# Accreditation and quality assurance
#################################################################

gias:AccreditationDate
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Accreditation date"@en ;
    skos:definition "The date on which an online provider was accredited."@en ;
    skos:scopeNote "Online-provider-specific presentation of the OpenDate field. The underlying database field is Establishment.OpenDate."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    skos:related gias:OpenDate ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: Establishment.OpenDate (relabelled for type 49)"@en .

gias:AccreditationExpiryDate
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Accreditation expiry date"@en ;
    skos:definition "The date on which the online provider's accreditation expires."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    skos:related gias:AccreditationDate ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: AccreditationExpiryDate"@en .

gias:AccreditationDateEnded
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Accreditation date ended"@en ;
    skos:definition "The date on which an online provider's accreditation ended."@en ;
    skos:scopeNote "Online-provider-specific presentation of the CloseDate field. The underlying database field is Establishment.CloseDate."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    skos:related gias:ClosedDate ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: Establishment.CloseDate (relabelled for type 49)"@en .

gias:QualityAssuranceBodyName
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Quality assurance body name"@en ;
    skos:altLabel "QABName"@en ;
    skos:definition "The name of the quality assurance body responsible for the online provider."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    skos:related gias:QualityAssuranceBodyReport ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: QABName"@en .

gias:QualityAssuranceBodyReport
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Quality assurance body report"@en ;
    skos:altLabel "QABReport"@en ;
    skos:definition "A link or reference to the quality assurance body's report for the online provider."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    skos:related gias:QualityAssuranceBodyName ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: QABReport"@en .

gias:CompaniesHouseNumber
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Companies House number"@en ;
    skos:altLabel "CHNumber"@en ;
    skos:definition "The Companies House registration number for the online provider."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: CHNumber"@en .

gias:EstablishmentAccredited
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Establishment accredited"@en ;
    skos:definition "The classification indicating whether the online provider holds current accreditation."@en ;
    skos:broader gias:AccreditationAndQualityAssurance ;
    skos:related gias:AccreditationDate, gias:AccreditationExpiryDate ;
    gias:status "Provisional"@en ;
    dcterms:source "Database field: EstablishmentAccredited"@en .

#################################################################
# External references
#################################################################

gias:InspectionReportReference
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Inspection report reference"@en ;
    skos:altLabel "Ofsted rating and reports"@en ;
    skos:definition "A link or reference to an Ofsted inspection report owned and published by an external inspection service."@en ;
    skos:scopeNote "Distinct from InspectorateReport, which is the inspectorate report link for British schools overseas."@en ;
    skos:broader gias:ExternalReference ;
    skos:related gias:InspectorateReport ;
    gias:status "Provisional"@en .

gias:ExternalServiceReference
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "External service reference"@en ;
    skos:altLabel "Data from other services"@en ;
    skos:definition "A link from GIAS to related information owned by another service."@en ;
    skos:broader gias:ExternalReference ;
    gias:status "Provisional"@en .
