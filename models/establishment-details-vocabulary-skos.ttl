    skos:related gias:ResourcedProvisionPupilCount ;
    gias:status "Preferred"@en ;
    dcterms:source "C#: ResourcedProvisionCapacity; Java: SpecialIndicators.resourcedProvisionCapacity; database: Establishment.ResourcedProvisionCapacity"@en .

gias:SenUnitPupilCount
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
