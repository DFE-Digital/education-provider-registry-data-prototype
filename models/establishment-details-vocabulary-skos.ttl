    skos:scopeNote "Observed on the Details tab for most school types with a religious character. A database-mapping gap exists for non-maintained special schools (type 08); the underlying configuration should be verified."@en ;
    skos:broader epr:FaithContext ;
    skos:related epr:ReligiousCharacter ;
    epr:status "Preferred"@en .

