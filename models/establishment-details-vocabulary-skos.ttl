        epr:NotApplicableReligiousCharacter,
        epr:OtherReligiousCharacter,
        epr:RomanCatholicCharacter ;
    epr:status "Preferred"@en ;
    dcterms:source "C#: ReligiousCharacterId; Java: Characteristics.religiousCharacter; database: Establishment.religiousCharacter_code"@en .

epr:ReligiousEthos
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsVocabulary ;
    skos:prefLabel "Religious ethos"@en ;
    skos:definition "The recorded religious-ethos classification associated with an establishment."@en ;
    skos:broader epr:FaithContext ;
    skos:related epr:ReligiousCharacter ;
    skos:narrower
        epr:ChristianEthos,
        epr:NoReligiousEthos,
        epr:NotApplicableReligiousEthos,
        epr:OtherReligiousEthos ;
