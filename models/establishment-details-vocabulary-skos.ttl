#################################################################
# Capacity and pupil measures
#################################################################

gias:SchoolCapacity
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "School capacity"@en ;
    skos:altLabel "Capacity"@en ;
    skos:definition "The number of pupils the school is organised or planned to provide for."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    gias:status "Preferred"@en ;
    dcterms:source "Java: Characteristics.schoolCapacity; database: Establishment.SchoolCapacity"@en .

gias:PupilCount
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Pupil count"@en ;
    skos:altLabel "Number of pupils"@en, "Number of Pupils"@en ;
    skos:definition "The number of pupils recorded for the establishment at the stated census date."@en ;
    skos:scopeNote "The measure is incomplete without its effective or census date."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    skos:related gias:CensusDate ;
    gias:status "Preferred"@en .

gias:CensusDate
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Census date"@en ;
    skos:definition "The effective date for pupil-count and related census measures."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    skos:related gias:PupilCount, gias:PupilsEligibleForFreeSchoolMeals ;
    gias:status "Preferred"@en .

gias:PupilsEligibleForFreeSchoolMeals
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Pupils eligible for free school meals"@en ;
    skos:altLabel "Number of pupils eligible for free school meals"@en ;
    skos:definition "The number of pupils whose families have claimed eligibility for free school meals."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    skos:related gias:CensusDate, gias:PercentagePupilsEligibleForFreeSchoolMeals ;
    gias:status "Preferred"@en .

gias:PercentagePupilsEligibleForFreeSchoolMeals
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
    skos:prefLabel "Percentage of pupils eligible for free school meals"@en ;
    skos:altLabel "Percentage of Pupils Receiving FSM"@en, "PercentageFSM"@en ;
    skos:definition "The proportion of pupils recorded as eligible for free school meals."@en ;
    skos:scopeNote "Receiving FSM is a misleading legacy alias because the measure concerns eligibility claims, not whether pupils received meals."@en ;
    skos:broader gias:CapacityAndPupilMeasures ;
    skos:related gias:CensusDate, gias:PupilsEligibleForFreeSchoolMeals ;
    gias:status "Preferred"@en .

gias:SpecialPupilsOnStatementOrEhcPlan
    a skos:Concept ;
    skos:inScheme gias:establishmentDetailsVocabulary ;
