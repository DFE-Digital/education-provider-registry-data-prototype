    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:minCount 1 ;
        sh:name "Sixth-form provision"@en ;
        sh:message "Mainstream academies must have a sixth-form-provision classification."@en ;
    ] .


#################################################################
# Specific shape — Academy special schools
#
# Covers: Academy special sponsor led, Academy special converter
#################################################################

epr:AcademySpecialShape
    a sh:NodeShape ;
    rdfs:label "Academy special school shape"@en ;
    rdfs:comment "Rules for academy special schools. Academy trust is required; SEN provision is required; admissions policy, nursery and sixth-form provision are not applicable."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType ?type .
                VALUES ?type {
                    epr:AcademySpecialSponsorLed
                    epr:AcademySpecialConverter
                }
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:minCount 1 ;
        sh:name "Academy trust"@en ;
        sh:message "Academy special schools must have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:minCount 1 ;
        sh:name "SEN and resourced provision"@en ;
        sh:message "Academy special schools must have a SEN and resourced provision record."@en ;
