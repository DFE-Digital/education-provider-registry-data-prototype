        sh:message "Admissions policy is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:maxCount 0 ;
        sh:name "Nursery provision (not applicable)"@en ;
        sh:message "Nursery provision is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByBoardingProvision ) ;
        sh:maxCount 0 ;
        sh:name "Boarding provision (not applicable)"@en ;
        sh:message "Boarding provision is not applicable for pupil referral units."@en ;
    ] .


#################################################################
# Specific shape — Local authority nursery school
#################################################################

epr:LocalAuthorityNurserySchoolShape
    a sh:NodeShape ;
    rdfs:label "Local authority nursery school shape"@en ;
    rdfs:comment "Rules for LA nursery schools. Admissions policy and sixth-form provision are not applicable."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType epr:LocalAuthorityNurserySchool .
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEducationPhase ) ;
        sh:minCount 1 ;
        sh:name "Education phase"@en ;
        sh:message "LA nursery schools must have an education phase (expected: Nursery)."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:maxCount 0 ;
        sh:name "Admissions policy (not applicable)"@en ;
        sh:message "Admissions policy is not applicable for LA nursery schools."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for LA nursery schools."@en ;
    ] .


#################################################################
# Group shape — Non-maintained special schools
#
# Covers: Non-maintained special school,
#         Other independent special school
#################################################################

epr:NonMaintainedSpecialSchoolGroupShape
    a sh:NodeShape ;
    rdfs:label "Non-maintained special school group shape"@en ;
    rdfs:comment "Rules for non-maintained and independent special schools. Proprietor is required; SEN provision is required; admissions policy and sixth-form provision are not applicable."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType ?type .
                VALUES ?type {
                    epr:NonMaintainedSpecialSchool
                    epr:OtherIndependentSpecialSchool
                }
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:minCount 1 ;
        sh:name "Proprietor"@en ;
        sh:message "Non-maintained special schools must have a proprietor accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:maxCount 0 ;
        sh:name "Local authority — accountability relationship (not applicable)"@en ;
        sh:message "Non-maintained special schools are not LA maintained and must not have an LA accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (not applicable)"@en ;
        sh:message "Non-maintained special schools must not have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:minCount 1 ;
        sh:name "SEN and resourced provision"@en ;
        sh:message "Non-maintained special schools must have a SEN and resourced provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:maxCount 0 ;
        sh:name "Admissions policy (not applicable)"@en ;
        sh:message "Admissions policy is not applicable for non-maintained special schools."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for non-maintained special schools."@en ;
    ] .


#################################################################
# Group shape — Independent schools
#
# Covers: City technology college, Other independent school
#################################################################

epr:IndependentSchoolGroupShape
    a sh:NodeShape ;
    rdfs:label "Independent school group shape"@en ;
    rdfs:comment "Rules for independent schools (city technology colleges and other independent schools). Proprietor is required; education phase, gender of entry, admissions policy and boarding provision are required."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType ?type .
                VALUES ?type {
                    epr:CityTechnologyCollege
                    epr:OtherIndependentSchool
                }
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:minCount 1 ;
        sh:name "Proprietor"@en ;
        sh:message "Independent schools must have a proprietor accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:maxCount 0 ;
        sh:name "Local authority — accountability relationship (not applicable)"@en ;
        sh:message "Independent schools must not have an LA accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (not applicable)"@en ;
        sh:message "Independent schools must not have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEducationPhase ) ;
        sh:minCount 1 ;
        sh:name "Education phase"@en ;
        sh:message "Independent schools must have an education phase."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEducationAdmissionsAndProvision ;
        sh:minCount 1 ;
        sh:name "Education, admissions and provision"@en ;
        sh:message "Independent schools must have an education, admissions and provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByGenderOfEntry ) ;
        sh:minCount 1 ;
        sh:name "Gender of entry"@en ;
        sh:message "Independent schools must have a gender-of-entry classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:minCount 1 ;
        sh:name "Admissions policy"@en ;
        sh:message "Independent schools must have an admissions policy."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByBoardingProvision ) ;
        sh:minCount 1 ;
        sh:name "Boarding provision"@en ;
        sh:message "Independent schools must have a boarding-provision classification."@en ;
    ] .


#################################################################
# Group shape — Mainstream academies
#
# Covers: Academy sponsor led, Academy converter
#################################################################

epr:MainstreamAcademyGroupShape
    a sh:NodeShape ;
    rdfs:label "Mainstream academy group shape"@en ;
    rdfs:comment "Rules for mainstream academy types. Academy trust is required; education phase, gender of entry, admissions policy, boarding, nursery and sixth-form provision are all required."@en ;
    sh:target [
