@prefix epr:     <https://dfe-digital.github.io/education-provider-registry-data/vocabulary/> .
@prefix epro:    <https://dfe-digital.github.io/education-provider-registry-data/ontology/> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# GIAS 2.0 Establishment Details — SHACL Shapes
#
# Scope: field-applicability constraints for the ~39 GIAS establishment types.
# Shapes are organised by type group. Rules within a group apply to every type
# in that group unless a more specific shape overrides them.
#
# Sits alongside:
#   establishment-details-conceptual-model.ttl  (OWL ontology)
#   establishment-details-taxonomy-skos.ttl     (SKOS taxonomy)
#   establishment-details-vocabulary-skos.ttl   (SKOS vocabulary)
#
# All shapes are provisional. Rules for "Other types" (secure units, offshore
# schools, service children's education, miscellaneous, British schools overseas,
# institution funded by other government department) require further data analysis
# before strong constraints can be added.


#################################################################
# Shapes graph declaration
#################################################################

<https://dfe-digital.github.io/education-provider-registry-data/shapes/>
    a owl:Ontology ;
    dcterms:title "GIAS 2.0 Establishment Details SHACL Shapes"@en ;
    dcterms:description "SHACL node shapes expressing per-type and per-group field-applicability rules for GIAS establishment records."@en ;
    dcterms:created "2026-06-19"^^xsd:date ;
    dcterms:modified "2026-06-19"^^xsd:date ;
    dcterms:publisher "Department for Education"@en ;
    dcterms:license <https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    owl:versionInfo "0.3" ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-data/ontology/> ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-data/taxonomy/> ;
    epr:status "Provisional"@en .


#################################################################
# SPARQL prefix declarations (used by SPARQLTarget blocks)
#################################################################

epr:sparqlPrefixes
    a owl:Ontology ;
    sh:declare
        [ sh:prefix "epr"  ; sh:namespace "https://dfe-digital.github.io/education-provider-registry-data/vocabulary/"^^xsd:anyURI ] ,
        [ sh:prefix "epro" ; sh:namespace "https://dfe-digital.github.io/education-provider-registry-data/ontology/"^^xsd:anyURI ] .


#################################################################
# Universal shape — applies to every establishment
#################################################################

epr:EstablishmentUniversalShape
    a sh:NodeShape ;
    rdfs:label "Universal establishment shape"@en ;
    rdfs:comment "Constraints that apply to every establishment regardless of type."@en ;
    sh:targetClass epr:Establishment ;

    sh:property [
        sh:path epro:hasEstablishmentIdentity ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment identity"@en ;
        sh:message "Every establishment must have exactly one identity record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentIdentity epro:identifiedByUrn ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "URN"@en ;
        sh:message "Every establishment identity must include exactly one URN."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEstablishmentLifecycle ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment lifecycle"@en ;
        sh:message "Every establishment must have exactly one lifecycle record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentLifecycle epro:classifiedByEstablishmentStatus ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment status"@en ;
        sh:message "Every establishment lifecycle must carry exactly one status."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEstablishmentClassification ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment classification"@en ;
        sh:message "Every establishment must have exactly one classification record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEstablishmentType ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment type"@en ;
        sh:message "Every establishment classification must carry exactly one establishment type."@en ;
    ] ;

    sh:property [
        sh:path epro:hasContactAndLocation ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Contact and location"@en ;
        sh:message "Every establishment must have exactly one contact and location record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasPostalAddress ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Postal address"@en ;
        sh:message "Every establishment must have a postal address."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasHeadteacherOrPrincipal ) ;
        sh:maxCount 1 ;
        sh:name "Headteacher or principal"@en ;
        sh:message "An establishment may have at most one headteacher or principal record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasWebsiteUrl ) ;
        sh:maxCount 1 ;
        sh:name "Website"@en ;
        sh:message "An establishment may have at most one website URL."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasTelephoneNumber ) ;
        sh:maxCount 1 ;
        sh:name "Telephone number"@en ;
        sh:message "An establishment may have at most one telephone number."@en ;
    ] .


#################################################################
# Group shape — LA maintained schools
#
# Covers: Community school, Voluntary aided school,
#         Voluntary controlled school, Foundation school,
#         Community special school, Foundation special school,
#         Pupil referral unit, Local authority nursery school
#################################################################

epr:LaMaintainedSchoolGroupShape
    a sh:NodeShape ;
    rdfs:label "LA maintained school group shape"@en ;
    rdfs:comment "Rules shared by all LA maintained school types. More specific shapes override individual fields for special schools, PRUs and nursery schools."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType ?type .
                VALUES ?type {
                    epr:CommunitySchool
                    epr:VoluntaryAidedSchool
                    epr:VoluntaryControlledSchool
                    epr:FoundationSchool
                    epr:CommunitySpecialSchool
                    epr:FoundationSpecialSchool
                    epr:PupilReferralUnit
                    epr:LocalAuthorityNurserySchool
                }
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:minCount 1 ;
        sh:name "Local authority"@en ;
        sh:message "LA maintained schools must have at least one local authority accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (forbidden)"@en ;
        sh:message "LA maintained schools must not have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:maxCount 0 ;
        sh:name "Proprietor (forbidden)"@en ;
        sh:message "LA maintained schools must not have a proprietor accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEducationAdmissionsAndProvision ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Education, admissions and provision"@en ;
        sh:message "LA maintained schools must have an education, admissions and provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByGenderOfEntry ) ;
        sh:minCount 1 ;
        sh:name "Gender of entry"@en ;
        sh:message "LA maintained schools must have a gender-of-entry classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByBoardingProvision ) ;
        sh:minCount 1 ;
        sh:name "Boarding provision"@en ;
        sh:message "LA maintained schools must have a boarding-provision classification."@en ;
    ] .


#################################################################
# Specific shape — LA mainstream schools
#
# Covers: Community school, Voluntary aided school,
#         Voluntary controlled school, Foundation school
#################################################################

epr:LaMainstreamSchoolShape
    a sh:NodeShape ;
    rdfs:label "LA mainstream school shape"@en ;
    rdfs:comment "Rules for mainstream LA maintained school types. Admissions policy, nursery, sixth form and education phase are all required."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType ?type .
                VALUES ?type {
                    epr:CommunitySchool
                    epr:VoluntaryAidedSchool
                    epr:VoluntaryControlledSchool
                    epr:FoundationSchool
                }
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEducationPhase ) ;
        sh:minCount 1 ;
        sh:name "Education phase"@en ;
        sh:message "LA mainstream schools must have an education phase."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:minCount 1 ;
        sh:name "Admissions policy"@en ;
        sh:message "LA mainstream schools must have an admissions policy."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:minCount 1 ;
        sh:name "Nursery provision"@en ;
        sh:message "LA mainstream schools must have a nursery-provision classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:minCount 1 ;
        sh:name "Sixth-form provision"@en ;
        sh:message "LA mainstream schools must have a sixth-form-provision classification."@en ;
    ] .


#################################################################
# Specific shape — LA special schools
#
# Covers: Community special school, Foundation special school
#################################################################

epr:LaSpecialSchoolShape
    a sh:NodeShape ;
    rdfs:label "LA special school shape"@en ;
    rdfs:comment "Rules for LA maintained special schools. SEN provision is required. Admissions policy, nursery provision and sixth-form provision are not applicable."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType ?type .
                VALUES ?type {
                    epr:CommunitySpecialSchool
                    epr:FoundationSpecialSchool
                }
            }
        """ ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:minCount 1 ;
        sh:name "SEN and resourced provision"@en ;
        sh:message "LA special schools must have a SEN and resourced provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:maxCount 0 ;
        sh:name "Admissions policy (not applicable)"@en ;
        sh:message "LA special schools do not use an admissions policy — places are allocated by local authority decision, not standard admissions."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:maxCount 0 ;
        sh:name "Nursery provision (not applicable)"@en ;
        sh:message "Nursery provision is not applicable for LA special schools."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for LA special schools."@en ;
    ] .


