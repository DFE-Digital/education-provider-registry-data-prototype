    a sh:NodeShape ;
    rdfs:label "Online provider shape"@en ;
    rdfs:comment "Rules for online providers. LA and academy trust accountability relationships are not applicable. Boarding and nursery provision are not applicable. Education phase, gender of entry, admissions policy, official sixth form, faith context and proprietor's name are all present in the GIAS record. Note: open date represents accreditation date and closed date represents accreditation date ended in the public Details view."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType epr:OnlineProvider .
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:maxCount 0 ;
        sh:name "Local authority — accountability relationship (not applicable)"@en ;
        sh:message "Online providers do not have LA accountability relationships."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (not applicable)"@en ;
        sh:message "Online providers do not have academy trust accountability relationships."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByBoardingProvision ) ;
        sh:maxCount 0 ;
        sh:name "Boarding provision (not applicable)"@en ;
        sh:message "Boarding provision is not applicable for online providers."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:maxCount 0 ;
        sh:name "Nursery provision (not applicable)"@en ;
        sh:message "Nursery provision is not applicable for online providers."@en ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:maxCount 0 ;
        sh:name "SEN and resourced provision (not applicable)"@en ;
        sh:message "SEN and resourced provision is not applicable for online providers."@en ;
    ] .


#################################################################
# Specific shape — Welsh establishment
#################################################################

epr:WelshEstablishmentShape
    a sh:NodeShape ;
    rdfs:label "Welsh establishment shape"@en ;
    rdfs:comment "Rules for Welsh establishments. LA accountability and education phase are required. Gender of entry, admissions policy and boarding provision are not present in the GIAS record for Welsh establishments and are not modelled as required here."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType epr:WelshEstablishment .
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:minCount 1 ;
        sh:name "Local authority"@en ;
        sh:message "Welsh establishments must have a local authority accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (not applicable)"@en ;
        sh:message "Welsh establishments must not have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:maxCount 0 ;
        sh:name "Proprietor (not applicable)"@en ;
        sh:message "Welsh establishments must not have a proprietor accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEducationPhase ) ;
        sh:minCount 1 ;
        sh:name "Education phase"@en ;
        sh:message "Welsh establishments must have an education phase."@en ;
    ] .


#################################################################
# Specific shape — Special post-16 institution
#################################################################

epr:SpecialPost16Shape
    a sh:NodeShape ;
    rdfs:label "Special post-16 institution shape"@en ;
    rdfs:comment "Rules for special post-16 institutions. SEN provision is required; admissions policy, nursery and sixth-form provision are not applicable."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType epr:SpecialPost16Institution .
            }
        """ ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:minCount 1 ;
        sh:name "SEN and resourced provision"@en ;
        sh:message "Special post-16 institutions must have a SEN and resourced provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:maxCount 0 ;
        sh:name "Admissions policy (not applicable)"@en ;
        sh:message "Admissions policy is not applicable for special post-16 institutions."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:maxCount 0 ;
        sh:name "Nursery provision (not applicable)"@en ;
        sh:message "Nursery provision is not applicable for special post-16 institutions."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for special post-16 institutions."@en ;
    ] .


#################################################################
# Specific shape — British schools overseas
#################################################################

epr:BritishSchoolsOverseasShape
    a sh:NodeShape ;
    rdfs:label "British schools overseas shape"@en ;
    rdfs:comment "Rules for British schools overseas. Proprietor is required; no LA or academy trust applies; education phase and gender of entry are required."@en ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:prefixes epr:sparqlPrefixes ;
        sh:select """
            SELECT ?this WHERE {
                ?this a epr:Establishment ;
                    epro:hasEstablishmentClassification/epro:hasEstablishmentType epr:BritishSchoolsOverseas .
            }
        """ ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:minCount 1 ;
        sh:name "Proprietor"@en ;
        sh:message "British schools overseas must have a proprietor accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:maxCount 0 ;
        sh:name "Local authority — accountability relationship (not applicable)"@en ;
        sh:message "British schools overseas must not have an LA accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (not applicable)"@en ;
        sh:message "British schools overseas must not have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEducationPhase ) ;
        sh:minCount 1 ;
        sh:name "Education phase"@en ;
        sh:message "British schools overseas must have an education phase."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByGenderOfEntry ) ;
        sh:minCount 1 ;
        sh:name "Gender of entry"@en ;
        sh:message "British schools overseas must have a gender-of-entry classification."@en ;
    ] .


# Note: Secure units (24), Offshore schools (25), Service children's education (26),
# Miscellaneous (27) and Institution funded by other government department (56)
# have variable field applicability that requires further analysis of actual GIAS data
# before strong constraints can be added. No specific shapes are defined for these types
# in this version.
